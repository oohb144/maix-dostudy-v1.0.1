@echo off
REM ============================================================
REM  固定语音 WAV 生成脚本（Windows）
REM  实际逻辑在 gen_voice.py，本 bat 只负责调用并防止闪退。
REM  生成后把 dist\voice\ 整目录拷到板子 /root/voice/
REM ============================================================
cd /d "%~dp0\.."
chcp 65001 >nul

echo ============================================================
echo   固定语音 WAV 生成（16 条）
echo   依赖：Python + 网络（首次会自动 pip install edge-tts）
echo ============================================================
echo.

python scripts\gen_voice.py
if errorlevel 1 (
    echo.
    echo [出错] 生成未完成，请看上方日志。
)

echo.
echo ============================================================
echo  如显示 "完成：成功 16 / 失败 0"，则把 dist\voice\ 拷到板子 /root/voice/
echo ============================================================
pause